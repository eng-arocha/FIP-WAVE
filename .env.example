# ─── Supabase ───────────────────────────────────────────────────────────────
# Encontre em: supabase.com → seu projeto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
# Service role — NUNCA exposto ao browser — usado apenas em API routes
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ─── App URL ─────────────────────────────────────────────────────────────────
# Em produção: URL do Vercel (ex: https://fip-wave.vercel.app)
# Em desenvolvimento: http://localhost:3000
NEXT_PUBLIC_APP_URL=https://fip-wave.vercel.app

# ─── E-mail Transacional (Resend) ────────────────────────────────────────────
# Encontre em: resend.com → API Keys
RESEND_API_KEY=re_...
# Domínio verificado no Resend (ex: medicoes@fipengenharia.com.br)
FROM_EMAIL=medicoes@fipengenharia.com.br
